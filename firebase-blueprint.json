{
  "entities": {
    "Message": {
      "title": "Message",
      "description": "A contact message submitted via the website.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the sender."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "Email address of the sender."
        },
        "message": {
          "type": "string",
          "description": "The message content."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the message was submitted."
        }
      },
      "required": ["name", "email", "message", "createdAt"]
    }
  },
  "firestore": {
    "/messages/{messageId}": {
      "schema": { "$ref": "#/entities/Message" },
      "description": "Collection of contact messages."
    }
  }
}
